# ============================================
# Basetrack — Production Environment Variables
# Copy this to .env and fill in the values
# ============================================

# --- Database ---
DB_USER=basetrack
DB_PASSWORD=change_me_to_secure_password
DB_NAME=basetrack

# --- Ports (optional) ---
TRACKER_PORT=3000
WS_PORT=8081

# --- Internal API Key ---
# Used for service-to-service auth (ws ↔ tracker ↔ cron)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change_me_to_secure_random_key

# --- Session ---
# Used for cookie encryption
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_secure_random_key

# --- Basecamp OAuth ---
# Get from: https://launchpad.37signals.com/integrations
BASECAMP_CLIENT_ID=your_basemp_client_id
BASECAMP_CLIENT_SECRET=your_basemp_client_secret
BASECAMP_REDIRECT_URI=https://your-domain.com/auth/callback

# --- Google OAuth ---
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# --- WebSocket (Public URL) ---
# This is the WebSocket URL that the browser connects to
# Use wss:// for HTTPS, ws:// for HTTP
WS_PUBLIC_URL=wss://your-domain.com/ws
