{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "basetrack",
  "version": "0.1.4",
  "identifier": "dev.basetrack.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Basetrack",
        "width": 350,
        "height": 40,
        "minWidth": 350,
        "minHeight": 40,
        "maxWidth": 350,
        "maxHeight": 40,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
